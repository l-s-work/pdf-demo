OSS_ENABLED=true
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=your-bucket
OSS_ACCESS_KEY_ID=your-ak
OSS_ACCESS_KEY_SECRET=your-sk
OSS_OBJECT_PREFIX=pdf
OSS_SIGN_EXPIRES_SECONDS=1800

# OCR settings for scanned PDF hit detection.
OCR_LANGUAGE=ch
OCR_DPI=150
# PaddleX cache directory. This is the real model cache used by PaddleOCR.
# PADDLE_PDX_CACHE_HOME=D:\path\to\paddlex-cache
# Backward-compatible alias, optional.
# PADDLE_OCR_BASE_DIR=D:\path\to\paddlex-cache
# Disable model hoster connectivity check during startup.
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True

# 本地开发时开启 worker 热重载。
# WORKER_RELOAD=true
# WORKER_RELOAD_PATHS=app
